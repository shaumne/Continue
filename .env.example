# Continue — client env. Copy to `.env` and fill. EXPO_PUBLIC_* is bundled into
# the app, so ONLY put public values here (Supabase anon key is safe to expose;
# it is gated by Row Level Security). Never put service-role keys or provider
# secrets here — those live in Supabase Edge Function secrets.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Provider secrets are NOT set here. Set them on the server:
#   supabase secrets set TMDB_TOKEN=... IGDB_CLIENT_ID=... IGDB_CLIENT_SECRET=... STEAM_API_KEY=...
